generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Product {
  id            String   @id @default(cuid())
  name          String
  category      String
  quantity      Int      @default(0)
  costPrice     Float
  sellingPrice  Float
  lowStockAlert Int      @default(5)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Sale {
  id          String   @id @default(cuid())
  invoiceNo   String   @unique
  productName String
  quantity    Int
  unitPrice   Float
  costPrice   Float
  totalAmount Float
  profit      Float
  createdAt   DateTime @default(now())
}

model Repair {
  id             String       @id @default(cuid())
  customerName   String
  contactNumber  String
  deviceType     String
  deviceModel    String
  problemDesc    String
  repairCost     Float
  technicianCost Float
  profit         Float
  status         RepairStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum RepairStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}